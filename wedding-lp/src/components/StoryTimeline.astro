---
import type { WeddingData } from '../types/wedding';
import { formatStoryDate } from '../utils/format';

interface Props {
  data: WeddingData;
}

const { data } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section
  id="story"
  class="section-padding reveal bg-ivory dark:bg-[#1a1816]"
  aria-labelledby="story-title"
>
  <div class="mx-auto max-w-5xl text-center">
    <h2 id="story-title" class="section-title">
      {data.ui['story.title']}
    </h2>
    <p class="section-subtitle mx-auto normal-case tracking-normal">
      {data.ui['story.subtitle']}
    </p>
    <div class="gold-divider"></div>
  </div>

  <ol class="relative mx-auto mt-16 max-w-3xl space-y-0">
    <div
      class="absolute top-0 bottom-0 left-4 w-px bg-gradient-to-b from-gold/0 via-gold/40 to-gold/0 sm:left-1/2 sm:-translate-x-px"
      aria-hidden="true"
    ></div>

    {
      data.story.map((item, index) => (
        <li
          class:list={[
            'reveal relative flex flex-col gap-6 pb-16 sm:flex-row sm:items-center sm:gap-10',
            index % 2 === 1 ? 'sm:flex-row-reverse' : '',
          ]}
        >
          <div class="relative z-10 flex shrink-0 items-center sm:w-1/2 sm:justify-end sm:pr-12">
            <div
              class:list={[
                'ml-8 sm:ml-0',
                index % 2 === 1 ? 'sm:pl-12 sm:pr-0 sm:text-left' : 'sm:pr-12 sm:text-right',
              ]}
            >
              <time
                datetime={item.date}
                class="text-xs tracking-[0.2em] text-gold uppercase"
              >
                {formatStoryDate(item.date)}
              </time>
              <h3 class="mt-2 font-display text-2xl">{item.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-ink-muted dark:text-[#a89f94]">
                {item.description}
              </p>
            </div>
          </div>

          <div
            class="absolute top-6 left-4 h-3 w-3 -translate-x-1/2 rounded-full border-2 border-gold bg-ivory sm:left-1/2 dark:bg-[#1a1816]"
            aria-hidden="true"
          ></div>

          <figure class="relative z-10 ml-16 overflow-hidden rounded-2xl shadow-lg sm:ml-0 sm:w-1/2">
            <img
              src={`${base}${item.image.replace(/^\//, '')}`}
              alt={item.alt}
              class="aspect-[4/5] w-full object-cover transition-transform duration-700 hover:scale-105"
              loading="lazy"
              decoding="async"
              width="600"
              height="750"
            />
          </figure>
        </li>
      ))
    }
  </ol>
</section>
