---
import type { WeddingData } from '../types/wedding';

interface Props {
  data: WeddingData;
}

const { data } = Astro.props;
const { dressCode } = data;
const base = import.meta.env.BASE_URL;
---

<section
  id="dress-code"
  class="section-padding reveal bg-ivory dark:bg-[#221f1c]"
  aria-labelledby="dress-code-title"
>
  <div class="mx-auto max-w-4xl text-center">
    <h2 id="dress-code-title" class="section-title">
      {dressCode.title}
    </h2>
    <div class="gold-divider"></div>

    <p class="mx-auto mt-6 max-w-2xl text-sm leading-relaxed text-ink-muted dark:text-[#a89f94]">
      {dressCode.description}
    </p>

    {
      dressCode.images.length > 0 && (
        <>
          <p class="mt-12 text-[0.65rem] tracking-[0.25em] text-ink-muted uppercase">
            {data.ui['dressCode.inspiration']}
          </p>
          <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
            {dressCode.images.map((src) => (
              <figure class="overflow-hidden rounded-2xl shadow-md">
                <img
                  src={`${base}${src.replace(/^\//, '')}`}
                  alt=""
                  class="aspect-[3/4] w-full object-cover transition-transform duration-500 hover:scale-105"
                  loading="lazy"
                  decoding="async"
                  width="400"
                  height="533"
                />
              </figure>
            ))}
          </div>
        </>
      )
    }
  </div>
</section>
