---
import type { WeddingData } from '../types/wedding';

interface Props {
  data: WeddingData;
}

const { data } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section
  id="gallery"
  class="section-padding reveal bg-champagne/30 dark:bg-[#221f1c]"
  aria-labelledby="gallery-title"
>
  <div class="mx-auto max-w-6xl text-center">
    <h2 id="gallery-title" class="section-title">
      {data.ui['gallery.title']}
    </h2>
    <p class="section-subtitle mx-auto normal-case tracking-normal">
      {data.ui['gallery.subtitle']}
    </p>
    <div class="gold-divider"></div>

    <div class="gallery-masonry mt-12" id="gallery-grid">
      {
        data.gallery.map((item, index) => (
          <button
            type="button"
            class="gallery-item group relative w-full overflow-hidden rounded-xl focus-visible:ring-2 focus-visible:ring-gold"
            data-gallery-index={index}
            data-src={`${base}${item.src.replace(/^\//, '')}`}
            data-alt={item.alt}
          >
            <img
              src={`${base}${item.src.replace(/^\//, '')}`}
              alt={item.alt}
              class="w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
              loading="lazy"
              decoding="async"
              width={item.width ?? 800}
              height={item.height ?? 600}
            />
            <span class="absolute inset-0 bg-black/0 transition-colors group-hover:bg-black/10" aria-hidden="true"></span>
          </button>
        ))
      }
    </div>
  </div>
</section>

<div
  id="lightbox"
  class="fixed inset-0 z-[70] flex items-center justify-center bg-black/90 p-4 opacity-0 pointer-events-none transition-opacity duration-300"
  role="dialog"
  aria-modal="true"
  aria-label="Galería de fotos"
  hidden
>
  <button
    type="button"
    id="lightbox-close"
    class="absolute top-4 right-4 rounded-full p-2 text-white/80 transition-colors hover:text-gold-light"
    aria-label={data.ui['gallery.close']}
  >
    <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  <button type="button" id="lightbox-prev" class="absolute left-2 p-3 text-white/70 hover:text-white sm:left-6" aria-label="Anterior">
    <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
    </svg>
  </button>
  <figure class="max-h-[85vh] max-w-[90vw]">
    <img
      id="lightbox-img"
      src=""
      alt=""
      class="max-h-[85vh] max-w-full rounded-lg object-contain transition-transform duration-300"
    />
  </figure>
  <button type="button" id="lightbox-next" class="absolute right-2 p-3 text-white/70 hover:text-white sm:right-6" aria-label="Siguiente">
    <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7" />
    </svg>
  </button>
</div>
