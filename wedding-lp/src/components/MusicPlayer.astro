---
import type { WeddingData } from '../types/wedding';

interface Props {
  data: WeddingData;
}

const { data } = Astro.props;
const { music } = data;
const audioSrc = `${import.meta.env.BASE_URL}${music.src.replace(/^\//, '')}`;

if (!music.enabled) return null;
---

<div
  id="music-player"
  class="fixed bottom-5 left-5 z-40 sm:bottom-8 sm:left-8"
  data-src={music.src}
  data-autoplay={music.autoplay !== false ? 'true' : 'false'}
>
  <button
    type="button"
    id="music-toggle"
    class="flex h-12 w-12 items-center justify-center rounded-full border border-gold/30 bg-ivory/90 text-gold shadow-lg backdrop-blur-sm transition-all hover:scale-105 hover:border-gold dark:bg-[#252220]/90"
    aria-label={data.ui['music.play']}
    aria-pressed="false"
  >
    <svg id="music-icon-play" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M8 5v14l11-7z" />
    </svg>
    <svg id="music-icon-pause" class="hidden h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />
    </svg>
  </button>
  <audio id="wedding-audio" src={audioSrc} preload="auto" loop playsinline></audio>
  <span class="sr-only">{music.title}</span>
</div>
